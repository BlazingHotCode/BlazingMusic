<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml - App manifest configuration -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
           xmlns:tools="http://schemas.android.com/tools">

    <!-- ============== PERMISSIONS ============== -->
    <!-- Read audio files - Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
    <!-- Read external storage - Android 12 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
                     android:maxSdkVersion="32"/>
    <!-- Allow foreground service for background playback -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <!-- Specific foreground service type for media playback -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <!-- Show notifications - Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- ============== APPLICATION ============== -->
    <application
            android:allowBackup="true"
            android:icon="@drawable/ic_launcher_foreground"
            android:label="@string/app_name"
            android:roundIcon="@drawable/ic_launcher_foreground"
            android:supportsRtl="true"
            android:theme="@style/Theme.BlazingMusic"
            tools:targetApi="34">

        <!-- ============== MAIN ACTIVITY ============== -->
        <activity
                android:name=".MainActivity"
                android:exported="true"
                android:theme="@style/Theme.BlazingMusic">
            <!-- App launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ============== MUSIC SERVICE ============== -->
        <!-- Background media playback service -->
        <service
                android:name=".MusicService"
                android:exported="false"
                android:foregroundServiceType="mediaPlayback">
            <!-- Media session service connection -->
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService"/>
            </intent-filter>
        </service>

    </application>

</manifest>
