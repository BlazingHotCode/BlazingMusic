<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BlazingMusic" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_lavender</item>
        <item name="colorPrimaryVariant">@color/accent_lavender_dark</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSecondary">@color/accent_lavender</item>
        <item name="colorSecondaryVariant">@color/accent_lavender_dark</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.BlazingMusic.Dialog</item>
        <item name="popupMenuStyle">@style/Widget.BlazingMusic.PopupMenu</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <style name="ThemeOverlay.BlazingMusic.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@color/bg_surface_alt</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.BlazingMusic.DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.BlazingMusic.DialogBody</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.BlazingMusic.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.BlazingMusic.DialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.BlazingMusic.DialogButton</item>
    </style>

    <style name="TextAppearance.BlazingMusic.DialogTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.BlazingMusic.DialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.BlazingMusic.DialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent_lavender</item>
        <item name="android:textAllCaps">false</item>
    </style>


    <style name="ThemeOverlay.BlazingMusic.PopupMenu" parent="ThemeOverlay.AppCompat.Dark">
        <item name="popupMenuStyle">@style/Widget.BlazingMusic.PopupMenu</item>
    </style>

    <style name="ThemeOverlay.BlazingMusic.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.BlazingMusic.BottomSheet</item>
    </style>

    <style name="ThemeOverlay.BlazingMusic.FullScreenDialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="Widget.BlazingMusic.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="android:background">@drawable/bg_bottom_sheet_surface</item>
    </style>

    <style name="Widget.BlazingMusic.PopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:itemTextAppearance">@style/TextAppearance.BlazingMusic.PopupMenuItem</item>
    </style>

    <style name="TextAppearance.BlazingMusic.PopupMenuItem" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
